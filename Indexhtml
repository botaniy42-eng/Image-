
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
  <title>PixelForge Studio Pro | 4K Ultra Edition</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"></script>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
      min-height: 100vh;
      padding: 24px;
      color: #f8fafc;
    }

    .app-container {
      max-width: 1600px;
      margin: 0 auto;
      background: rgba(30, 41, 59, 0.7);
      backdrop-filter: blur(12px);
      border-radius: 2rem;
      box-shadow: 0 25px 50px -12px rgba(0,0,0,0.4);
      overflow: hidden;
      border: 1px solid rgba(255, 255, 255, 0.08);
    }

    .editor-header {
      background: #1e293b;
      padding: 1.2rem 2rem;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .logo h1 {
      font-size: 1.6rem;
      font-weight: 700;
      background: linear-gradient(120deg, #38bdf8, #a855f7);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .logo p {
      font-size: 0.75rem;
      color: #94a3b8;
    }

    .action-buttons {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }

    .btn {
      padding: 10px 22px;
      border-radius: 40px;
      font-weight: 600;
      font-size: 0.85rem;
      border: none;
      cursor: pointer;
      transition: all 0.2s ease;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: #334155;
      color: #f8fafc;
    }

    .btn-primary {
      background: #0284c7;
      color: white;
      box-shadow: 0 4px 12px rgba(2,132,199,0.3);
    }

    .btn-primary:hover {
      background: #0369a1;
      transform: translateY(-1px);
    }

    .btn-magic {
      background: linear-gradient(135deg, #e11d48 0%, #a855f7 100%);
      color: white;
      box-shadow: 0 4px 15px rgba(225, 29, 72, 0.3);
    }

    .btn-magic:hover {
      filter: brightness(1.1);
      transform: translateY(-1px);
    }

    .btn-outline {
      background: transparent;
      border: 1px solid #475569;
    }

    .btn-outline:hover {
      background: #334155;
    }

    .editor-layout {
      display: flex;
      flex-wrap: wrap;
    }

    .canvas-area {
      flex: 3;
      min-width: 280px;
      background: #0f172a;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 2rem;
      min-height: 550px;
    }

    .image-wrapper {
      background: #1e293b;
      border-radius: 24px;
      box-shadow: 0 12px 28px rgba(0,0,0,0.3);
      padding: 12px;
    }

    .image-preview {
      max-width: 100%;
      max-height: 65vh;
      display: block;
      margin: 0 auto;
      border-radius: 16px;
    }

    .placeholder-message {
      text-align: center;
      color: #64748b;
      padding: 3rem;
    }

    .controls-panel {
      flex: 1.2;
      min-width: 280px;
      background: #1e293b;
      border-left: 1px solid #334155;
      padding: 1.5rem;
      max-height: 80vh;
      overflow-y: auto;
    }

    .control-group {
      border-bottom: 1px solid #334155;
      padding-bottom: 1.2rem;
      margin-bottom: 1.2rem;
    }

    .control-group h3 {
      font-size: 0.9rem;
      font-weight: 600;
      color: #94a3b8;
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .slider-container {
      margin-bottom: 12px;
    }

    .slider-container label {
      font-size: 0.8rem;
      color: #cbd5e1;
      display: flex;
      justify-content: space-between;
      margin-bottom: 6px;
    }

    input[type="range"] {
      width: 100%;
      height: 6px;
      -webkit-appearance: none;
      background: #334155;
      border-radius: 4px;
    }

    input[type="range"]::-webkit-slider-thumb {
      -webkit-appearance: none;
      width: 16px;
      height: 16px;
      background: #38bdf8;
      border-radius: 50%;
      cursor: pointer;
    }

    .filter-buttons {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .filter-chip {
      background: #334155;
      color: #cbd5e1;
      padding: 6px 14px;
      border-radius: 40px;
      font-size: 0.75rem;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.2s;
    }

    .filter-chip.active {
      background: #0284c7;
      color: white;
    }

    .filter-chip:hover:not(.active) {
      background: #475569;
    }

    .small-btn {
      background: #334155;
      color: white;
      border: none;
      padding: 8px 14px;
      border-radius: 30px;
      font-size: 0.75rem;
      font-weight: 600;
      cursor: pointer;
      margin: 4px;
    }

    .small-btn:hover {
      background: #475569;
    }

    .value-display {
      font-size: 0.7rem;
      font-weight: 600;
      background: #0f172a;
      color: #38bdf8;
      padding: 2px 8px;
      border-radius: 20px;
    }

    #resBadge {
      font-size: 0.75rem;
      background: #111827;
      color: #10b981;
      padding: 4px 10px;
      border-radius: 6px;
      display: none;
      margin-top: 8px;
    }

    @media (max-width: 780px) {
      body { padding: 12px; }
      .controls-panel { max-height: 45vh; }
    }
  </style>
</head>
<body>
<div class="app-container">
  <div class="editor-header">
    <div class="logo">
      <h1><i class="fas fa-bolt"></i> PixelForge Ultra</h1>
      <p>Professional Image Editor | No Lag</p>
      <div id="resBadge">Resolution: --</div>
    </div>
    <div class="action-buttons">
      <button id="upscale4KBtn" class="btn btn-magic" style="display: none;"><i class="fas fa-wand-magic-sparkles"></i> Smart 4K Upscale</button>
      <button id="uploadBtn" class="btn btn-primary"><i class="fas fa-cloud-upload-alt"></i> Upload</button>
      <input type="file" id="fileInput" accept="image/jpeg,image/png,image/webp" style="display: none">
      <button id="downloadBtn" class="btn btn-outline"><i class="fas fa-download"></i> Export PNG</button>
      <button id="resetBtn" class="btn btn-outline"><i class="fas fa-undo-alt"></i> Reset</button>
    </div>
  </div>

  <div class="editor-layout">
    <div class="canvas-area">
      <div class="image-wrapper">
        <canvas id="mainCanvas" class="image-preview" style="display: none;"></canvas>
        <div id="placeholderMsg" class="placeholder-message">
          <i class="fas fa-images" style="font-size: 3rem; opacity: 0.3; margin-bottom: 12px; display: block;"></i>
          Click "Upload" to start editing
        </div>
      </div>
    </div>

    <div class="controls-panel">
      <div class="control-group">
        <h3><i class="fas fa-sliders-h"></i> Adjustments</h3>
        <div class="slider-container">
          <label>Brightness <span id="brightnessVal" class="value-display">0</span></label>
          <input type="range" id="brightness" min="-100" max="100" value="0">
        </div>
        <div class="slider-container">
          <label>Contrast <span id="contrastVal" class="value-display">0</span></label>
          <input type="range" id="contrast" min="-100" max="100" value="0">
        </div>
        <div class="slider-container">
          <label>Saturation <span id="saturationVal" class="value-display">0</span></label>
          <input type="range" id="saturation" min="-100" max="100" value="0">
        </div>
        <div class="slider-container">
          <label>Blur <span id="blurVal" class="value-display">0</span></label>
          <input type="range" id="blur" min="0" max="10" value="0" step="0.5">
        </div>
      </div>

      <div class="control-group">
        <h3><i class="fas fa-magic"></i> Filters</h3>
        <div class="filter-buttons" id="filterContainer">
          <div data-filter="none" class="filter-chip active">Original</div>
          <div data-filter="grayscale" class="filter-chip">Grayscale</div>
          <div data-filter="sepia" class="filter-chip">Sepia</div>
          <div data-filter="invert" class="filter-chip">Invert</div>
          <div data-filter="vintage" class="filter-chip">Vintage</div>
        </div>
      </div>

      <div class="control-group">
        <h3><i class="fas fa-crop"></i> Transform</h3>
        <div>
          <button id="rotateLeftBtn" class="small-btn"><i class="fas fa-undo"></i> -90°</button>
          <button id="rotateRightBtn" class="small-btn"><i class="fas fa-redo"></i> +90°</button>
          <button id="flipXBtn" class="small-btn"><i class="fas fa-arrows-alt-h"></i> Flip H</button>
          <button id="flipYBtn" class="small-btn"><i class="fas fa-arrows-alt-v"></i> Flip V</button>
        </div>
        <div style="margin-top: 10px;">
          <button id="cropBtn" class="small-btn" style="background: #0284c7;">Start Crop</button>
          <button id="applyCropBtn" class="small-btn" style="background: #10b981; display: none;">Apply</button>
          <button id="cancelCropBtn" class="small-btn" style="background: #64748b; display: none;">Cancel</button>
        </div>
        <div id="cropNote" style="font-size: 11px; color: #94a3b8; margin-top: 6px;"></div>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  // DOM elements
  const canvas = document.getElementById('mainCanvas');
  const ctx = canvas.getContext('2d');
  const placeholderMsg = document.getElementById('placeholderMsg');
  const fileInput = document.getElementById('fileInput');
  const uploadBtn = document.getElementById('uploadBtn');
  const downloadBtn = document.getElementById('downloadBtn');
  const resetBtn = document.getElementById('resetBtn');
  const upscaleBtn = document.getElementById('upscale4KBtn');
  const resBadge = document.getElementById('resBadge');

  // Sliders
  const brightnessSlider = document.getElementById('brightness');
  const contrastSlider = document.getElementById('contrast');
  const saturationSlider = document.getElementById('saturation');
  const blurSlider = document.getElementById('blur');
  const brightnessVal = document.getElementById('brightnessVal');
  const contrastVal = document.getElementById('contrastVal');
  const saturationVal = document.getElementById('saturationVal');
  const blurVal = document.getElementById('blurVal');

  const filterChips = document.querySelectorAll('[data-filter]');
  const rotateLeftBtn = document.getElementById('rotateLeftBtn');
  const rotateRightBtn = document.getElementById('rotateRightBtn');
  const flipXBtn = document.getElementById('flipXBtn');
  const flipYBtn = document.getElementById('flipYBtn');
  const cropBtn = document.getElementById('cropBtn');
  const applyCropBtn = document.getElementById('applyCropBtn');
  const cancelCropBtn = document.getElementById('cancelCropBtn');
  const cropNote = document.getElementById('cropNote');

  // State
  let originalImage = null; // HTMLImageElement
  let imageLoaded = false;
  let renderScheduled = false;
  
  // Transform state
  let rotation = 0;
  let flipH = false;
  let flipV = false;
  
  // Adjustments
  let brightness = 0;
  let contrast = 0;
  let saturation = 0;
  let blur = 0;
  let currentFilter = 'none';
  
  // Crop
  let cropper = null;
  let cropMode = false;

  // Update display values
  function updateDisplays() {
    brightnessVal.textContent = brightness;
    contrastVal.textContent = contrast;
    saturationVal.textContent = saturation;
    blurVal.textContent = blur;
    brightnessSlider.value = brightness;
    contrastSlider.value = contrast;
    saturationSlider.value = saturation;
    blurSlider.value = blur;
  }

  // Update resolution badge
  function updateBadge() {
    if (imageLoaded && originalImage) {
      resBadge.textContent = `Resolution: ${originalImage.naturalWidth} x ${originalImage.naturalHeight}`;
      resBadge.style.display = 'inline-block';
      upscaleBtn.style.display = 'inline-flex';
    } else {
      resBadge.style.display = 'none';
      upscaleBtn.style.display = 'none';
    }
  }

  // Main render function - optimized to reduce lag
  function render() {
    if (!imageLoaded || !originalImage) return;
    
    const img = originalImage;
    let w = img.naturalWidth;
    let h = img.naturalHeight;
    
    // Apply rotation
    let rot = ((rotation % 360) + 360) % 360;
    let canvasW = (rot === 90 || rot === 270) ? h : w;
    let canvasH = (rot === 90 || rot === 270) ? w : h;
    
    // Create temporary canvas for transforms
    const tempCanvas = document.createElement('canvas');
    tempCanvas.width = canvasW;
    tempCanvas.height = canvasH;
    const tempCtx = tempCanvas.getContext('2d');
    
    tempCtx.save();
    tempCtx.translate(canvasW / 2, canvasH / 2);
    tempCtx.rotate(rot * Math.PI / 180);
    tempCtx.scale(flipH ? -1 : 1, flipV ? -1 : 1);
    tempCtx.drawImage(img, -w / 2, -h / 2, w, h);
    tempCtx.restore();
    
    // Apply filters and adjustments
    const filterCanvas = document.createElement('canvas');
    filterCanvas.width = canvasW;
    filterCanvas.height = canvasH;
    const filterCtx = filterCanvas.getContext('2d');
    filterCtx.drawImage(tempCanvas, 0, 0);
    
    const imageData = filterCtx.getImageData(0, 0, canvasW, canvasH);
    const data = imageData.data;
    
    // Calculate factors
    const bFactor = brightness / 100;
    const cFactor = (259 * (contrast + 255)) / (255 * (259 - contrast));
    const sFactor = 1 + (saturation / 100);
    
    for (let i = 0; i < data.length; i += 4) {
      let r = data[i];
      let g = data[i+1];
      let b = data[i+2];
      
      // Brightness
      r += 255 * bFactor;
      g += 255 * bFactor;
      b += 255 * bFactor;
      
      // Contrast
      r = cFactor * (r - 128) + 128;
      g = cFactor * (g - 128) + 128;
      b = cFactor * (b - 128) + 128;
      
      // Saturation
      const gray = 0.2989 * r + 0.5870 * g + 0.1140 * b;
      r = gray + (r - gray) * sFactor;
      g = gray + (g - gray) * sFactor;
      b = gray + (b - gray) * sFactor;
      
      // Clamp
      r = Math.min(255, Math.max(0, r));
      g = Math.min(255, Math.max(0, g));
      b = Math.min(255, Math.max(0, b));
      
      // Apply filter
      if (currentFilter !== 'none') {
        if (currentFilter === 'grayscale') {
          const gr = 0.299 * r + 0.587 * g + 0.114 * b;
          r = g = b = gr;
        } else if (currentFilter === 'sepia') {
          const tr = 0.393 * r + 0.769 * g + 0.189 * b;
          const tg = 0.349 * r + 0.686 * g + 0.168 * b;
          const tb = 0.272 * r + 0.534 * g + 0.131 * b;
          r = Math.min(255, tr);
          g = Math.min(255, tg);
          b = Math.min(255, tb);
        } else if (currentFilter === 'invert') {
          r = 255 - r;
          g = 255 - g;
          b = 255 - b;
        } else if (currentFilter === 'vintage') {
          r = Math.min(255, r * 0.9 + 40);
          g = Math.min(255, g * 0.85 + 30);
          b = Math.min(255, b * 0.8 + 20);
        }
      }
      
      data[i] = r;
      data[i+1] = g;
      data[i+2] = b;
    }
    
    filterCtx.putImageData(imageData, 0, 0);
    
    // Apply blur and draw to main canvas
    canvas.width = canvasW;
    canvas.height = canvasH;
    
    if (blur > 0) {
      ctx.filter = `blur(${blur}px)`;
    } else {
      ctx.filter = 'none';
    }
    
    ctx.drawImage(filterCanvas, 0, 0);
    ctx.filter = 'none';
    
    canvas.style.display = 'block';
    placeholderMsg.style.display = 'none';
  }
  
  // Debounced render to prevent lag
  let renderTimeout;
  function scheduleRender() {
    if (renderTimeout) clearTimeout(renderTimeout);
    renderTimeout = setTimeout(() => {
      render();
      renderScheduled = false;
    }, 50);
  }
  
  // Load image from file
  function loadImage(file) {
    if (!file) return;
    const reader = new FileReader();
    reader.onload = (e) => {
      const img = new Image();
      img.onload = () => {
        originalImage = img;
        imageLoaded = true;
        
        // Reset all transforms and adjustments
        rotation = 0;
        flipH = false;
        flipV = false;
        brightness = 0;
        contrast = 0;
        saturation = 0;
        blur = 0;
        currentFilter = 'none';
        
        updateDisplays();
        
        // Reset filter UI
        filterChips.forEach(chip => {
          if (chip.dataset.filter === 'none') chip.classList.add('active');
          else chip.classList.remove('active');
        });
        
        // Destroy cropper if active
        if (cropper) {
          cropper.destroy();
          cropper = null;
          cropMode = false;
          toggleCropUI(false);
        }
        
        updateBadge();
        render();
      };
      img.src = e.target.result;
    };
    reader.readAsDataURL(file);
  }
  
  // Toggle crop UI
  function toggleCropUI(active) {
    if (active) {
      cropBtn.style.display = 'none';
      applyCropBtn.style.display = 'inline-flex';
      cancelCropBtn.style.display = 'inline-flex';
      cropNote.textContent = 'Drag corners to select area, then click Apply';
    } else {
      cropBtn.style.display = 'inline-flex';
      applyCropBtn.style.display = 'none';
      cancelCropBtn.style.display = 'none';
      cropNote.textContent = '';
    }
  }
  
  // Start cropping
  function startCrop() {
    if (!imageLoaded || !canvas.style.display !== 'none') {
      if (cropper) cropper.destroy();
      cropper = new Cropper(canvas, {
        viewMode: 1,
        autoCropArea: 0.8,
        background: false
      });
      cropMode = true;
      toggleCropUI(true);
    }
  }
  
  // Apply crop
  function applyCrop() {
    if (!cropper) return;
    const croppedCanvas = cropper.getCroppedCanvas();
    if (croppedCanvas) {
      const croppedImg = new Image();
      croppedImg.onload = () => {
        originalImage = croppedImg;
        rotation = 0;
        flipH = false;
        flipV = false;
        cropper.destroy();
        cropper = null;
        cropMode = false;
        toggleCropUI(false);
        updateBadge();
        render();
      };
      croppedImg.src = croppedCanvas.toDataURL();
    }
  }
  
  // Cancel crop
  function cancelCrop() {
    if (cropper) {
      cropper.destroy();
      cropper = null;
    }
    cropMode = false;
    toggleCropUI(false);
    render();
  }
  
  // Reset everything
  function resetAll() {
    if (!imageLoaded) return;
    rotation = 0;
    flipH = false;
    flipV = false;
    brightness = 0;
    contrast = 0;
    saturation = 0;
    blur = 0;
    currentFilter = 'none';
    
    updateDisplays();
    
    filterChips.forEach(chip => {
      if (chip.dataset.filter === 'none') chip.classList.add('active');
      else chip.classList.remove('active');
    });
    
    if (cropper) {
      cropper.destroy();
      cropper = null;
      cropMode = false;
      toggleCropUI(false);
    }
    
    render();
  }
  
  // Smart 4K upscale using high-quality Lanczos-style resampling
  function upscaleTo4K() {
    if (!imageLoaded || !originalImage) return;
    
    let w = originalImage.naturalWidth;
    let h = originalImage.naturalHeight;
    
    let targetW = 3840;
    let targetH = Math.round((targetW / w) * h);
    
    // If already larger than 4K, double the size
    if (w >= 3840) {
      targetW = w * 2;
      targetH = h * 2;
    }
    
    const upCanvas = document.createElement('canvas');
    upCanvas.width = targetW;
    upCanvas.height = targetH;
    const upCtx = upCanvas.getContext('2d');
    
    // Enable high-quality image smoothing
    upCtx.imageSmoothingEnabled = true;
    upCtx.imageSmoothingQuality = 'high';
    upCtx.drawImage(originalImage, 0, 0, targetW, targetH);
    
    const upImg = new Image();
    upImg.onload = () => {
      originalImage = upImg;
      updateBadge();
      render();
      alert(`✨ Upscaled to ${targetW} x ${targetH} with high quality!`);
    };
    upImg.src = upCanvas.toDataURL('image/png');
  }
  
  // Event Listeners
  uploadBtn.addEventListener('click', () => fileInput.click());
  fileInput.addEventListener('change', (e) => {
    if (e.target.files[0]) loadImage(e.target.files[0]);
  });
  
  downloadBtn.addEventListener('click', () => {
    if (!imageLoaded) return;
    const link = document.createElement('a');
    link.download = `pixelforge_${Date.now()}.png`;
    link.href = canvas.toDataURL('image/png');
    link.click();
  });
  
  resetBtn.addEventListener('click', resetAll);
  upscaleBtn.addEventListener('click', upscaleTo4K);
  
  // Sliders with scheduleRender
  brightnessSlider.addEventListener('input', (e) => { brightness = parseInt(e.target.value); updateDisplays(); scheduleRender(); });
  contrastSlider.addEventListener('input', (e) => { contrast = parseInt(e.target.value); updateDisplays(); scheduleRender(); });
  saturationSlider.addEventListener('input', (e) => { saturation = parseInt(e.target.value); updateDisplays(); scheduleRender(); });
  blurSlider.addEventListener('input', (e) => { blur = parseFloat(e.target.value); updateDisplays(); scheduleRender(); });
  
  // Filters
  filterChips.forEach(chip => {
    chip.addEventListener('click', () => {
      currentFilter = chip.dataset.filter;
      filterChips.forEach(c => c.classList.remove('active'));
      chip.classList.add('active');
      render();
    });
  });
  
  // Transform buttons
  rotateLeftBtn.addEventListener('click', () => { rotation = (rotation - 90) % 360; render(); });
  rotateRightBtn.addEventListener('click', () => { rotation = (rotation + 90) % 360; render(); });
  flipXBtn.addEventListener('click', () => { flipH = !flipH; render(); });
  flipYBtn.addEventListener('click', () => { flipV = !flipV; render(); });
  
  // Crop buttons
  cropBtn.addEventListener('click', startCrop);
  applyCropBtn.addEventListener('click', applyCrop);
  cancelCropBtn.addEventListener('click', cancelCrop);
})();
</script>
</body>
</html>
